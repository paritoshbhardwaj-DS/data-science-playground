   "source": [
    "#print array in reverse - 1 2 3 4 -8 -10\n",
    "import numpy\n",
    "\n",
    "def arrays(arr):\n",
    "    arr.reverse()\n",
    "    return numpy.array((arr), float)\n",
    "\n",
    "arr = input().strip().split(' ')\n",
    "result = arrays(arr)\n",
    "print(result)"
   ],
